# --- CONFIGURATION (Example) ---
# Copy this file to .env and adjust values if needed.
# DO NOT commit the real .env file to version control.

# --- INFLUXDB SETUP ---
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=adminpassword123
INFLUXDB_INIT_ORG=HUS
INFLUXDB_INIT_BUCKET=api_metrics
INFLUXDB_INIT_ADMIN_TOKEN=my-super-secret-auth-token-hus-2024

# For backend connection
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=my-super-secret-auth-token-hus-2024
INFLUX_ORG=HUS
INFLUX_BUCKET=api_metrics

# --- BACKEND SETTINGS ---
# Scaling Limits
SOFT_LIMIT=50
HARD_LIMIT=5000
ANOMALY_THRESHOLD=0.15
SCALE_DOWN_COOLDOWN=60
BUFFER_K=0.1

# Redis
REDIS_HOST=redis_service

# --- FRONTEND (Vite) ---
# Must start with VITE_ to be exposed to client
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
